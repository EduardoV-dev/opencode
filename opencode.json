{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "openai": {
      "options": {
        "timeout": 600000,
        "chunkTimeout": 30000
      },
      "models": {
        "gpt-5.1-codex-max": {},
        "gpt-5.2": {},
        "gpt-5.2-codex": {},
        "gpt-5.3-codex": {},
        "gpt-5.4": {},
        "gpt-5.3-codex-spark": {},
        "gpt-5.1-codex-mini": {},
        "gpt-5.1-codex": {},
        "gpt-5-codex": {},
        "auto": {}
      }
    }
  },
  "default_agent": "vibe-coding",
  "model": "openai/gpt-5.3-codex",
  "small_model": "openai/gpt-5.1-codex-mini",
  "agent": {
    "build": {
      "mode": "primary",
      "model": "openai/gpt-5.3-codex",
      "permission": {
        "edit": "ask",
        "bash": "ask"
      }
    },
    "vibe-coding": {
      "mode": "primary",
      "model": "openai/gpt-5.3-codex",
      "permission": {
        "edit": "allow",
        "bash": "allow"
      }
    },
    "plan": {
      "mode": "primary",
      "model": "openai/gpt-5.4",
      "permission": {
        "edit": "deny",
        "bash": "deny"
      }
    }
  },
  "mcp": {
    "chrome": {
      "type": "local",
      "command": ["npx", "-y", "chrome-devtools-mcp"],
      "enabled": true
    }
  }
}
